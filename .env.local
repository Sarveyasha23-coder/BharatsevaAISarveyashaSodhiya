# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/bharatseva
MONGODB_TEST_URI=mongodb://127.0.0.1:27017/bharatseva-test

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_ORG_ID=your_openai_org_id_here

# JWT Configuration
JWT_SECRET=bharatseva_secret
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:5000

# OCR Configuration
TESSERACT_DATA_PATH=/usr/share/tesseract-ocr/4.00/tessdata

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Redis Configuration (Optional for caching)
REDIS_URL=redis://localhost:6379

# Speech Recognition Configuration
SPEECH_API_KEY=your_speech_api_key_here
SPEECH_REGION=your_speech_region_here

# Fraud Detection Configuration
FRAUD_DETECTION_THRESHOLD=0.7
FRAUD_API_ENDPOINT=https://api.fraud-detection.com

# Crop Disease Detection Configuration
CROP_DISEASE_MODEL_PATH=models/crop_disease_model.h5
CROP_DISEASE_CONFIDENCE_THRESHOLD=0.8

# Language Detection Configuration
LANGUAGE_DETECTION_API_KEY=your_language_api_key_here

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/bharatseva-ai.log

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Feature Flags
ENABLE_OCR=true
ENABLE_VOICE_RECOGNITION=true
ENABLE_FRAUD_DETECTION=true
ENABLE_CROP_DISEASE_DETECTION=true
ENABLE_LANGUAGE_DETECTION=true

# Analytics Configuration
GOOGLE_ANALYTICS_ID=your_google_analytics_id_here

# Development Configuration
DEBUG=true
MOCK_EXTERNAL_APIS=true
